def _setup_hooks_only() -> int:
    hook_source = REPO_ROOT / ".githooks" / "pre-commit"
    if not hook_source.exists():
        print_warn("no .githooks/pre-commit found; skipping hook install")
        return 0
    git_dir = REPO_ROOT / ".git"
    if not git_dir.is_dir():
        print_warn("not a git repo; skipping hook install")
        return 0
    hooks_dir = git_dir / "hooks"
    hooks_dir.mkdir(parents=True, exist_ok=True)
    target = hooks_dir / "pre-commit"
    target.write_bytes(hook_source.read_bytes())
    target.chmod(target.stat().st_mode | 0o111)
    print_ok("installed git hooks: pre-commit")
    return 0


def cmd_setup(_args: argparse.Namespace) -> int:
    _, _, setup_runtime = _try_import_dev_commands()
    if setup_runtime is None:
        result = _setup_hooks_only()
        if result == 0:
            print_ok("hooks installed (project-context runtime arrives on stack/3-mcp)")
        return result
    return setup_runtime(REPO_ROOT, print_ok, print_warn, print_error)


