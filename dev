        path = repo_path(raw)
        if not path.exists():
            continue
        text = path.read_text(encoding="utf-8")
        for snippet in snippets:
            if snippet in text:
                continue
            message = f"{raw} missing snippet: {snippet}"
            print_error(message)
            failures.append(message)
    for raw, snippets in forbidden_snippets.items():
        path = repo_path(raw)
        if not path.exists():
            continue
        text = path.read_text(encoding="utf-8")
        for snippet in snippets:
            if snippet not in text:
                continue
            message = f"{raw} still references forbidden snippet: {snippet}"
            print_error(message)
            failures.append(message)
    if not failures:
        print_ok("core docs match the control-plane contract")
    return failures


