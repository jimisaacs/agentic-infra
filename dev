def cmd_fmt(args: argparse.Namespace) -> int:
    return run_format(collect_paths(args.paths), check_only=args.check)


def cmd_setup(_args: argparse.Namespace) -> int:
    hook_target = git_path("hooks/pre-commit")
    hook_target.parent.mkdir(parents=True, exist_ok=True)
    shutil.copy2(repo_path(".githooks/pre-commit"), hook_target)
    os.chmod(hook_target, 0o755)
    print_ok(f"installed pre-commit hook: {hook_target}")
    return 0


def cmd_verify(_args: argparse.Namespace) -> int:
    t0 = time.monotonic()
    failures: list[str] = []
    failures.extend(check_required_paths())
    failures.extend(check_python_syntax())
    failures.extend(check_unit_tests())
    failures.extend(check_markdown_links())
    failures.extend(check_doc_contract())
    failures.extend(check_web_build())
    failures.extend(check_format_drift())

    elapsed = time.monotonic() - t0
    if failures:
        print_section("Result")
        print_error(f"verify failed ({len(failures)} issue(s)) {term.dim(f'({elapsed:.1f}s)')}")
        print("Run `./dev fmt` to fix formatting drift and then address the remaining issues.")
        return 1

    print_section("Result")
    print_ok(f"verify passed {term.dim(f'({elapsed:.1f}s)')}")
    return 0


def cmd_doctor(_args: argparse.Namespace) -> int:
    print_section("Doctor")
    failures = 0

    required = ["python3", "git", "docker"]
    for tool_name in required:
        if shutil.which(tool_name):
            print_ok(f"required: {tool_name}")
        else:
            print_error(f"required (missing): {tool_name}")
            failures += 1

    project_tools = {
        "go": "project/go/ compilation and ./dev stack dev",
        "node": "project/web/ type checking and ./dev stack dev",
        "npm": "project/web/ dependency management",
    }
    for tool_name, purpose in project_tools.items():
        if shutil.which(tool_name):
            print_ok(f"project: {tool_name} {term.dim(f'({purpose})')}")
        else:
            print_warn(f"project (missing): {tool_name} {term.dim(f'({purpose})')}")

    if not os.access(repo_path("dev"), os.X_OK):
        print_warn("`dev` is not executable; run `chmod +x dev` if needed")
    else:
        print_ok("`dev` is executable")

    if failures:
        print_error("doctor found missing required tooling")
        return 1
    print_ok("doctor passed")
    return 0


def cmd_status(_args: argparse.Namespace) -> int:
    print_section("Control plane")
    print(f"  repo root:  {REPO_ROOT}")
    print(f"  entrypoint: ./dev")
    print(f"  commands:   {', '.join(CORE_COMMANDS)}")

    print_section("Docs")
    for raw in ["README.md", "CONTRIBUTING.md", "project/README.md",
                "docs/PRINCIPLES.md", "docs/CONVENTIONS.md"]:
        path = repo_path(raw)
        state = term.green("present") if path.exists() else term.red("missing")
        print(f"  {raw}: {state}")

    print_section("Project")
    for raw in ["project/go", "project/web", "project/stack"]:
        path = repo_path(raw)
        state = term.green("present") if path.exists() else term.red("missing")
        print(f"  {raw}: {state}")

    print_section("Docker stack")
    if shutil.which("docker"):
        compose_dir = repo_path("project/stack")
        proc = subprocess.run(
            ["docker", "compose", "ps", "--format", "table {{.Name}}\t{{.Status}}\t{{.Ports}}"],
            cwd=compose_dir,
            capture_output=True,
            text=True,
        )
        if proc.returncode == 0 and proc.stdout.strip():
            for line in proc.stdout.strip().splitlines():
                print(f"  {line}")
        else:
            print(f"  {term.dim('no containers running')}")
    else:
        print(f"  {term.dim('docker not available')}")

    print_section("Git hooks")
    hook_path = repo_path(".githooks/pre-commit")
    print(f"  .githooks/pre-commit: {'present' if hook_path.exists() else 'missing'}")
    installed_hook = git_path("hooks/pre-commit")
    print(f"  installed pre-commit: {'present' if installed_hook.exists() else 'missing'}")
    return 0


# ---------------------------------------------------------------------------
# Stack commands
# ---------------------------------------------------------------------------

STACK_DIR = REPO_ROOT / "project" / "stack"
STACK_PORTS = [3000]

_FILES_DEV = ["compose.yml", "compose.dev.yml"]
_FILES_PROD = ["compose.yml", "compose.prod.yml"]
_FILES_ALL = ["compose.yml", "compose.dev.yml", "compose.prod.yml"]


def _compose_cmd(files: list[str]) -> list[str]:
    cmd = ["docker", "compose"]
    for f in files:
        cmd.extend(["-f", f])
    return cmd


def _ports_in_use(ports: list[int]) -> list[int]:
    import socket
    blocked: list[int] = []
    for port in ports:
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
            if s.connect_ex(("127.0.0.1", port)) == 0:
                blocked.append(port)
    return blocked


def _kill_containers_on_ports(ports: list[int]) -> None:
    """Force-remove any Docker container publishing to *ports*."""
    for port in ports:
        proc = subprocess.run(
            ["docker", "ps", "-q", "--filter", f"publish={port}"],
            capture_output=True, text=True, check=False,
        )
        for cid in proc.stdout.strip().splitlines():
            if not cid:
                continue
            print_warn(f"removing container {cid[:12]} holding port {port}")
            subprocess.run(
                ["docker", "rm", "-f", cid],
                capture_output=True, check=False,
            )


def _require_docker() -> None:
    if not shutil.which("docker"):
        print_error("docker is required for stack commands")
        print(f"  Run {term.bold('./dev doctor')} to check your tooling.")
        raise SystemExit(1)


def cmd_stack(args: argparse.Namespace) -> int:
    sub = getattr(args, "stack_command", None)
    if not sub:
        args._parser.print_help()  # noqa: SLF001
        return 0

    t0 = time.monotonic()

    if sub == "up":
        _require_docker()
        blocked = _ports_in_use(STACK_PORTS)
        if blocked:
            print_error(f"port(s) already in use: {blocked}")
            print(f"  Run {term.bold('./dev stack reset')} to clean up orphan containers.")
            return 1
        prod = getattr(args, "prod", False)
        files = _FILES_PROD if prod else _FILES_DEV
        mode = "prod" if prod else "dev"
        print(f"\n{term.bold(f'Starting Docker stack ({mode})...')}\n")
        run_cmd(_compose_cmd(files) + ["up", "--build", "--remove-orphans", "-d"], cwd=STACK_DIR)
        elapsed = time.monotonic() - t0
        print(f"\n{term.green(term.sym_ok)} Stack is up {term.dim(f'({mode}, {elapsed:.1f}s)')}")
        print(f"  Pulse: {term.bold('http://localhost:3000')}")
        return 0

    if sub == "down":
        _require_docker()
        run_cmd(_compose_cmd(_FILES_ALL) + ["down", "--remove-orphans"], cwd=STACK_DIR)
        print_ok("stack stopped")
        return 0

    if sub == "logs":
        _require_docker()
        try:
            run_cmd(_compose_cmd(_FILES_ALL) + ["logs", "-f"], cwd=STACK_DIR, check=False)
        except KeyboardInterrupt:
            pass
        return 0

    if sub == "status":
        _require_docker()
        run_cmd(_compose_cmd(_FILES_ALL) + ["ps"], cwd=STACK_DIR, check=False)
        return 0

    if sub == "reset":
        _require_docker()
        print(f"\n{term.bold('Resetting Docker stack to blank slate...')}\n")
        run_cmd(
            _compose_cmd(_FILES_ALL) + ["down", "--rmi", "all", "--volumes", "--remove-orphans"],
            cwd=STACK_DIR,
        )
        _kill_containers_on_ports(STACK_PORTS)
        still_blocked = _ports_in_use(STACK_PORTS)
        if still_blocked:
            print_warn(f"ports still occupied after cleanup: {still_blocked}")
            print("  A non-Docker process may be holding the port.")
        elapsed = time.monotonic() - t0
        print_ok(f"stack reset complete {term.dim(f'({elapsed:.1f}s)')}")
        print("  Containers, images, volumes, and orphans removed.")
        print(f"  Run {term.bold('./dev stack up')} to rebuild from scratch.")
        return 0

    if sub == "dev":
        return _stack_dev()

    print_error(f"unknown stack command: {sub}")
    return 2


def _stack_dev() -> int:
    for tool_name in ("go", "npm"):
        if not shutil.which(tool_name):
            print_error(f"{tool_name} is required for ./dev stack dev")
            print(f"  Run {term.bold('./dev doctor')} to check your tooling.")
            return 1

    import socket
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        if s.connect_ex(("127.0.0.1", 8080)) == 0:
            print_error("port 8080 is already in use")
            return 1

    web_dir = repo_path("project/web")
    go_dir = repo_path("project/go/app")
    static_dir = str(repo_path("project/web/dist"))

    if not (web_dir / "node_modules").is_dir():
        print(f"\n{term.bold('Installing web dependencies...')}\n")
        run_cmd(["npm", "install"], cwd=web_dir)

    print(f"\n{term.bold('Building web assets...')}\n")
    run_cmd(["npm", "run", "build"], cwd=web_dir)

    print(f"{term.bold('Starting file watcher')} {term.dim('(rebuilds on change)')}")
    vite_proc = subprocess.Popen(
        ["npx", "vite", "build", "--watch"],
        cwd=web_dir,
        stdout=subprocess.DEVNULL,
    )
    _children.append(vite_proc)

    print(f"\n{term.bold('Compiling Go server...')}\n")
    run_cmd(["go", "build", "-o", os.devnull, "."], cwd=go_dir)

    print(f"{term.bold('Starting Go server')} {term.dim('(:8080)')}")
    print(f"\n  {term.sym_arrow} {term.bold('http://localhost:8080')}\n")

    go_proc = subprocess.Popen(
        ["go", "run", ".", "-static", static_dir],
        cwd=go_dir,
    )
    _children.append(go_proc)

    try:
        go_proc.wait()
    except KeyboardInterrupt:
        pass
    finally:
        _cleanup_children()

    return 0


# ---------------------------------------------------------------------------
# Parser
# ---------------------------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="./dev",
        description="Human-first control plane for the worked-example project baseline.",
    )
    subparsers = parser.add_subparsers(dest="command")

    help_parser = subparsers.add_parser("help", help="Show control-plane help")
    help_parser.set_defaults(func=lambda _args: (parser.print_help(), 0)[1])

    setup_parser = subparsers.add_parser("setup", help="Install the clone-local pre-commit hook")
    setup_parser.set_defaults(func=cmd_setup)

    verify_parser = subparsers.add_parser("verify", help="Run baseline self-verification")
    verify_parser.set_defaults(func=cmd_verify)

    fmt_parser = subparsers.add_parser("fmt", help="Normalize lightweight text formatting")
    fmt_parser.add_argument("--check", action="store_true", help="Report formatting drift without rewriting")
    fmt_parser.add_argument("paths", nargs="*", help="Optional file or directory paths to scope")
    fmt_parser.set_defaults(func=cmd_fmt)

    doctor_parser = subparsers.add_parser("doctor", help="Check required local tooling")
    doctor_parser.set_defaults(func=cmd_doctor)

    status_parser = subparsers.add_parser("status", help="Show control-plane and project status")
    status_parser.set_defaults(func=cmd_status)

    stack_parser = subparsers.add_parser("stack", help="Manage the Docker stack")
    stack_parser.set_defaults(func=cmd_stack, _parser=stack_parser)
    stack_sub = stack_parser.add_subparsers(dest="stack_command")
    up_parser = stack_sub.add_parser("up", help="Build and start the Docker stack")
    up_parser.add_argument("--prod", action="store_true", help="Production mode (no file watcher)")
    stack_sub.add_parser("down", help="Stop the Docker stack")
    stack_sub.add_parser("logs", help="Stream Docker stack logs")
    stack_sub.add_parser("status", help="Show running containers")
    stack_sub.add_parser("reset", help="Remove all containers, images, and volumes")
    stack_sub.add_parser("dev", help="Start Go + Vite dev servers on host")

    return parser


def main(argv: list[str] | None = None) -> int:
    setup_signals()
    parser = build_parser()
    args = parser.parse_args(argv)
    if not args.command:
        parser.print_help()
        return 0
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
