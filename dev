def check_guard_behavior() -> list[str]:
    print_section("Guard behavior")
    failures: list[str] = []
    cases = [
        ("git status", 0, "allow status"),
        ("/usr/bin/git log --oneline -1", 0, "allow absolute-path git log"),
        ("git worktree list", 0, "allow worktree list"),
        ("git commit -m test", 0, "allow commit (controlled mutation)"),
        ("git add .", 0, "allow add (controlled mutation)"),
        ("git branch -D demo", 2, "block branch deletion"),
        ("git status && git commit -m test", 2, "block compound shell command"),
        ("git -C /tmp status", 2, "block repo-hopping global options"),
        ("git diff --no-index a b", 2, "block no-index diff"),
    ]
    for command, expected, label in cases:
        actual = run_guard(command)
        if actual == expected:
            print_ok(label)
            continue
        message = f"{label}: expected {expected}, got {actual}"
        print_error(message)
        failures.append(message)
    return failures


