# ---------------------------------------------------------------------------
# Terminal awareness
# ---------------------------------------------------------------------------

class Terminal:
    def __init__(self) -> None:
        self.is_tty = sys.stdout.isatty()
        self.color = self._should_color()
        self.unicode = self._should_unicode()

    def _should_color(self) -> bool:
        if os.environ.get("NO_COLOR") is not None:
            return False
        if os.environ.get("CLICOLOR_FORCE", "0") != "0":
            return True
        if not self.is_tty:
            return False
        term = os.environ.get("TERM", "")
        if term == "dumb":
            return False
        return True

    def _should_unicode(self) -> bool:
        if not self.is_tty:
            return False
        lang = os.environ.get("LANG", "") + os.environ.get("LC_ALL", "")
        return "UTF-8" in lang.upper() or "UTF8" in lang.upper()

    def _ansi(self, code: str, text: str) -> str:
        if not self.color:
            return text
        return f"\033[{code}m{text}\033[0m"

    def green(self, text: str) -> str:
        return self._ansi("32", text)

    def red(self, text: str) -> str:
        return self._ansi("31", text)

    def yellow(self, text: str) -> str:
        return self._ansi("33", text)

    def cyan(self, text: str) -> str:
        return self._ansi("36", text)

    def dim(self, text: str) -> str:
        return self._ansi("2", text)

    def bold(self, text: str) -> str:
        return self._ansi("1", text)

    @property
    def sym_ok(self) -> str:
        return "\u2714" if self.unicode else "[ok]"

    @property
    def sym_err(self) -> str:
        return "\u2718" if self.unicode else "[error]"

    @property
    def sym_warn(self) -> str:
        return "\u26a0" if self.unicode else "[warn]"

    @property
    def sym_arrow(self) -> str:
        return "\u2192" if self.unicode else "->"


term = Terminal()


def print_section(title: str) -> None:
    print(f"\n{term.bold(term.cyan(f'== {title} =='))}")


def print_ok(message: str) -> None:
    print(f"{term.green(term.sym_ok)} {message}")


def print_warn(message: str) -> None:
    print(f"{term.yellow(term.sym_warn)} {message}")


def print_error(message: str) -> None:
    print(f"{term.red(term.sym_err)} {message}")


# ---------------------------------------------------------------------------
# Signal handling
# ---------------------------------------------------------------------------

_children: list[subprocess.Popen] = []  # type: ignore[type-arg]


def _cleanup_children() -> None:
    for proc in _children:
        if proc.poll() is None:
            try:
                proc.terminate()
            except OSError:
                pass
    deadline = time.monotonic() + 5.0
    for proc in _children:
        remaining = max(0, deadline - time.monotonic())
        try:
            proc.wait(timeout=remaining)
        except subprocess.TimeoutExpired:
            try:
                proc.kill()
            except OSError:
                pass


def setup_signals() -> None:
    if hasattr(signal, "SIGPIPE"):
        signal.signal(signal.SIGPIPE, signal.SIG_DFL)

    def _handle_term(signum: int, _frame: object) -> None:
        _cleanup_children()
        sys.exit(128 + signum)

    signal.signal(signal.SIGTERM, _handle_term)


atexit.register(_cleanup_children)


# ---------------------------------------------------------------------------
# Subprocess helper
# ---------------------------------------------------------------------------

def run_cmd(
    cmd: list[str],
    *,
    cwd: Path | None = None,
    capture: bool = False,
    check: bool = True,
) -> subprocess.CompletedProcess[str]:
    sys.stdout.flush()
    sys.stderr.flush()
    try:
        return subprocess.run(
            cmd,
            cwd=cwd or REPO_ROOT,
            capture_output=capture,
            text=True,
            check=check,
        )
    except FileNotFoundError:
        print_error(f"command not found: {cmd[0]}")
        raise SystemExit(1)
    except subprocess.CalledProcessError as exc:
        if not capture:
            raise SystemExit(exc.returncode)
        raise


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def rel(path: Path) -> str:
    return path.relative_to(REPO_ROOT).as_posix()


def repo_path(raw: str) -> Path:
    return REPO_ROOT / raw


def git_path(raw: str) -> Path:
    proc = subprocess.run(
        ["git", "rev-parse", "--git-path", raw],
        cwd=REPO_ROOT,
        capture_output=True,
        text=True,
        check=False,
    )
    if proc.returncode != 0:
        raise SystemExit(proc.returncode)
    return Path(proc.stdout.strip()).resolve()


def is_text_path(path: Path) -> bool:
    if any(part in EXCLUDED_PARTS for part in path.parts):
        return False
    return path.suffix in TEXT_SUFFIXES or path.name in SPECIAL_FILENAMES


def iter_repo_text_files() -> Iterable[Path]:
    for path in sorted(REPO_ROOT.rglob("*")):
        if path.is_file() and is_text_path(path):
            yield path


def collect_paths(raw_paths: list[str]) -> list[Path]:
    if not raw_paths:
        return list(iter_repo_text_files())

    collected: list[Path] = []
    seen: set[Path] = set()

    for raw in raw_paths:
        candidate = Path(raw)
        if not candidate.is_absolute():
            candidate = (Path.cwd() / candidate).resolve()
        else:
            candidate = candidate.resolve()

        try:
            candidate.relative_to(REPO_ROOT)
        except ValueError as exc:
            raise SystemExit(f"path outside repo root: {raw}") from exc

        if not candidate.exists():
            raise SystemExit(f"path does not exist: {raw}")

        if candidate.is_dir():
            for nested in sorted(candidate.rglob("*")):
                if nested.is_file() and is_text_path(nested) and nested not in seen:
                    seen.add(nested)
                    collected.append(nested)
            continue

        if is_text_path(candidate) and candidate not in seen:
            seen.add(candidate)
            collected.append(candidate)

    return collected


def normalize_text(text: str) -> str:
    if text == "":
        return ""
    lines = text.splitlines()
    normalized = "\n".join(line.rstrip(" \t") for line in lines)
    return normalized + "\n"


# ---------------------------------------------------------------------------
# Format
# ---------------------------------------------------------------------------

def run_format(paths: list[Path], check_only: bool) -> int:
    changed: list[Path] = []
    for path in paths:
        original = path.read_text(encoding="utf-8")
        normalized = normalize_text(original)
        if normalized == original:
            continue
        changed.append(path)
        if not check_only:
            path.write_text(normalized, encoding="utf-8")

    if changed:
        action = "would format" if check_only else "formatted"
        for path in changed:
            print(f"{action}: {rel(path)}")
        return 1 if check_only else 0

    print("format: no changes needed")
    return 0


# ---------------------------------------------------------------------------
# Verification checks
# ---------------------------------------------------------------------------

def check_required_paths() -> list[str]:
    print_section("Required paths")
    failures: list[str] = []
    for raw in REQUIRED_PATHS:
        path = repo_path(raw)
        if path.exists():
            print_ok(raw)
            continue
        print_error(f"missing: {raw}")
        failures.append(raw)
    return failures


def check_python_syntax() -> list[str]:
    print_section("Python syntax")
    failures: list[str] = []
    for raw in PYTHON_PARSE_PATHS:
        path = repo_path(raw)
        try:
            compile(path.read_text(encoding="utf-8"), str(path), "exec")
        except SyntaxError as exc:
            print_error(f"python compile failed: {raw} ({exc})")
            failures.append(raw)
            continue
        except Exception as exc:  # noqa: BLE001
            print_error(f"python compile failed: {raw} ({exc})")
            failures.append(raw)
            continue
        print_ok(raw)
    return failures


def check_unit_tests() -> list[str]:
    print_section("Unit tests")
    proc = subprocess.run(
        ["python3", "-m", "unittest", "discover", "-s", "tests"],
        cwd=REPO_ROOT,
        capture_output=True,
        text=True,
    )
    if proc.returncode == 0:
        print_ok("unit tests passed")
        return []
    print_error("unit tests failed")
    sys.stderr.write(proc.stdout)
    sys.stderr.write(proc.stderr)
    return ["unit tests failed"]


def should_skip_link(target: str) -> bool:
    if target.startswith(("http://", "https://", "mailto:", "#")):
        return True
    if target.startswith("<") and target.endswith(">"):
        return True
    return False


def check_markdown_links() -> list[str]:
    print_section("Markdown links")
    failures: list[str] = []
    docs = sorted(
        [
            path
            for path in REPO_ROOT.rglob("*")
            if path.is_file()
            and path.suffix in {".md"}
            and not any(part in EXCLUDED_PARTS for part in path.parts)
        ]
    )
    for doc in docs:
        text = doc.read_text(encoding="utf-8")
        for match in LINK_PATTERN.finditer(text):
            raw_target = match.group(1).strip()
            if should_skip_link(raw_target):
                continue
            target = raw_target.split("#", 1)[0]
            if target == "" or "*" in target:
                continue
            resolved = (doc.parent / target).resolve()
            try:
                resolved.relative_to(REPO_ROOT)
            except ValueError:
                continue
            if resolved.exists():
                continue
            message = f"{rel(doc)} -> {raw_target}"
            print_error(message)
            failures.append(message)
    if not failures:
        print_ok("all markdown links resolve")
    return failures


def check_doc_contract() -> list[str]:
    print_section("Doc contract")
    failures: list[str] = []
    required_snippets: dict[str, list[str]] = {
        "README.md": [
            "project/README.md",
            "./dev verify",
            "docs/PRINCIPLES.md",
        ],
        "CONTRIBUTING.md": [
            "./dev verify",
            "./dev fmt",
        ],
        "project/README.md": [
            "project/{ecosystem}/{target}/",
            "## Quick Start",
        ],
        "docs/PRINCIPLES.md": [
            "## Core",
        ],
        "docs/CONVENTIONS.md": [
            "## Formatting",
        ],
    }
    for raw, snippets in required_snippets.items():
        path = repo_path(raw)
        if not path.exists():
            continue
        text = path.read_text(encoding="utf-8")
        for snippet in snippets:
            if snippet in text:
                continue
            message = f"{raw} missing snippet: {snippet}"
            print_error(message)
            failures.append(message)
    if not failures:
        print_ok("baseline docs match the control-plane contract")
    return failures


def check_format_drift() -> list[str]:
    print_section("Formatting drift")
    failures: list[str] = []
    for path in iter_repo_text_files():
        original = path.read_text(encoding="utf-8")
        normalized = normalize_text(original)
        if normalized == original:
            continue
        print_error(f"format drift: {rel(path)}")
        failures.append(rel(path))
    if not failures:
        print_ok("format check clean")
    return failures


def check_web_build() -> list[str]:
    print_section("Web build")
    if not shutil.which("docker"):
        print_error("docker not available (required for web build verification)")
        return ["docker not available"]
    proc = subprocess.run(
        _compose_cmd(_FILES_PROD) + ["build", "web"],
        cwd=STACK_DIR,
        capture_output=True,
        text=True,
    )
    if proc.returncode == 0:
        print_ok("web build passed (tsc + vite)")
        return []
    print_error("web build failed")
    sys.stderr.write(proc.stdout)
    sys.stderr.write(proc.stderr)
    return ["web build failed"]


